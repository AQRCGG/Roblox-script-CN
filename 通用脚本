-- 飞行功能
local flying = false
local flyConnection
local upButton, downButton
local autoRotateOriginal = true
local faceCameraWhileFlying = false

local flyBtn = Instance.new("TextButton")
flyBtn.Size = UDim2.new(0, 220, 0, 35)
flyBtn.Position = UDim2.new(0, 15, 0, yOffset)
flyBtn.Text = "✈️ 飞行开关 (关)"
flyBtn.BackgroundColor3 = Color3.fromRGB(255, 255, 200)
flyBtn.TextColor3 = Color3.new(0, 0, 0)
flyBtn.TextScaled = true
flyBtn.Font = Enum.Font.SourceSans
flyBtn.Parent = contentFrame
yOffset = yOffset + 45

flyBtn.MouseButton1Click:Connect(function()
	local char = player.Character or player.CharacterAdded:Wait()
	local hrp = char:FindFirstChild("HumanoidRootPart")
	if not hrp then return end

	flying = not flying
	if flying then
		if humanoid then
			autoRotateOriginal = humanoid.AutoRotate
			humanoid.AutoRotate = false
		end

		local bodyVel = Instance.new("BodyVelocity")
		bodyVel.Name = "FlyForce"
		bodyVel.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
		bodyVel.Velocity = Vector3.new(0, 0, 0)
		bodyVel.Parent = hrp

		-- 创建上下飞行按钮（直接放在gui下，始终可见）
		upButton = Instance.new("TextButton")
		upButton.Size = UDim2.new(0, 50, 0, 50)
		upButton.Position = UDim2.new(0, 320, 0, 120)
		upButton.Text = "▲"
		upButton.BackgroundColor3 = Color3.fromRGB(255, 255, 0)
		upButton.TextColor3 = Color3.new(0, 0, 0)
		upButton.Parent = gui

		downButton = Instance.new("TextButton")
		downButton.Size = UDim2.new(0, 50, 0, 50)
		downButton.Position = UDim2.new(0, 320, 0, 180)
		downButton.Text = "▼"
		downButton.BackgroundColor3 = Color3.fromRGB(255, 255, 0)
		downButton.TextColor3 = Color3.new(0, 0, 0)
		downButton.Parent = gui

		local up = false
		local down = false

		upButton.MouseButton1Down:Connect(function()
			up = true
		end)
		upButton.MouseButton1Up:Connect(function()
			up = false
		end)
		downButton.MouseButton1Down:Connect(function()
			down = true
		end)
		downButton.MouseButton1Up:Connect(function()
			down = false
		end)

		-- 用于强力悬停的BodyPosition
		local hoverPosition = nil

		flyConnection = RunService.RenderStepped:Connect(function()
			local camera = workspace.CurrentCamera
			if not camera then return end

			local hrp = bodyVel.Parent
			if not hrp or not hrp:IsDescendantOf(workspace) then
				flying = false
				flyConnection:Disconnect()
				return
			end

			local camCF = camera.CFrame
			local forward = camCF.LookVector
			local right = camCF.RightVector

			local moveDir = Vector3.new()
			local moving = false
			if UserInputService:IsKeyDown(Enum.KeyCode.W) then
				moveDir = moveDir + forward
				moving = true
			end
			if UserInputService:IsKeyDown(Enum.KeyCode.S) then
				moveDir = moveDir - forward
				moving = true
			end
			if UserInputService:IsKeyDown(Enum.KeyCode.A) then
				moveDir = moveDir - right
				moving = true
			end
			if UserInputService:IsKeyDown(Enum.KeyCode.D) then
				moveDir = moveDir + right
				moving = true
			end

			if up then
				moveDir = moveDir + Vector3.new(0, flySpeed, 0)
				moving = true
			end
			if down then
				moveDir = moveDir - Vector3.new(0, flySpeed, 0)
				moving = true
			end

			if moveDir.Magnitude > 0 then
				moveDir = moveDir.Unit * flySpeed
			end

			-- 强力悬停：无输入时锁定位置
			if not moving then
				if not hoverPosition then
					hoverPosition = Instance.new("BodyPosition")
					hoverPosition.Name = "HoverLock"
					hoverPosition.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
					hoverPosition.P = 2000
					hoverPosition.D = 100
					hoverPosition.Position = hrp.Position
					hoverPosition.Parent = hrp
				else
					hoverPosition.Position = hrp.Position  -- 持续锁定当前位置
				end
				-- 确保bodyVel不干扰
				bodyVel.Velocity = Vector3.new(0,0,0)
			else
				if hoverPosition then
					hoverPosition:Destroy()
					hoverPosition = nil
				end
				bodyVel.Velocity = moveDir
			end

			-- 如果开启朝向摄像机，则设置角色方向为摄像机全角度
			if faceCameraWhileFlying then
				local camCF = camera.CFrame
				hrp.CFrame = CFrame.lookAt(hrp.Position, hrp.Position + camCF.LookVector, camCF.UpVector)
			end
		end)

		flyBtn.Text = "✈️ 飞行开关 (开)"
	else
		if flyConnection then
			flyConnection:Disconnect()
			flyConnection = nil
		end
		-- 清理可能残留的悬停锁定
		if hrp and hrp:FindFirstChild("HoverLock") then
			hrp.HoverLock:Destroy()
		end
		if hrp and hrp:FindFirstChild("FlyForce") then
			hrp.FlyForce:Destroy()
		end
		if upButton then upButton:Destroy() upButton = nil end
		if downButton then downButton:Destroy() downButton = nil end

		if humanoid then
			humanoid.AutoRotate = autoRotateOriginal
		end

		flyBtn.Text = "✈️ 飞行开关 (关)"
	end
end)

