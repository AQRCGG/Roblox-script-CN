-- 辅助函数：创建带标签的滑动条+输入框（无上限）
local function createSliderInput(labelText, defaultValue, minVal, maxVal, onChange)
	-- 标签
	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(1, -10, 0, 25)
	label.Position = UDim2.new(0, 5, 0, yOffset)
	label.Text = labelText
	label.BackgroundTransparency = 1
	label.TextColor3 = Color3.new(0, 0, 0)
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.TextScaled = true
	label.Font = Enum.Font.SourceSans
	label.Parent = contentFrame
	yOffset = yOffset + 25

	-- 滑动条轨道
	local track = Instance.new("TextButton")
	track.Size = UDim2.new(0, 200, 0, 10)
	track.Position = UDim2.new(0, 40, 0, yOffset)
	track.BackgroundColor3 = Color3.fromRGB(150, 150, 150)
	track.Text = ""
	track.AutoButtonColor = false
	track.Parent = contentFrame

	-- 滑块
	local thumb = Instance.new("TextButton")
	thumb.Size = UDim2.new(0, 10, 0, 20)
	thumb.Position = UDim2.new(0, 0, 0, -5)
	thumb.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
	thumb.Text = ""
	thumb.Parent = track

	-- 数值输入框
	local valueBox = Instance.new("TextBox")
	valueBox.Size = UDim2.new(0, 60, 0, 25)
	valueBox.Position = UDim2.new(0, 250, 0, yOffset-5)
	valueBox.Text = tostring(defaultValue)
	valueBox.BackgroundColor3 = Color3.fromRGB(255, 255, 200)
	valueBox.TextColor3 = Color3.new(0,0,0)
	valueBox.TextScaled = true
	valueBox.Font = Enum.Font.SourceSans
	valueBox.Parent = contentFrame

	local currentValue = defaultValue
	local min = minVal
	local max = maxVal

	local function updateValue(newVal)
		newVal = tonumber(newVal) or defaultValue
		currentValue = newVal
		valueBox.Text = tostring(math.floor(newVal * 100) / 100)
		local percent = (newVal - min) / (max - min)
		percent = math.clamp(percent, 0, 1)
		thumb.Position = UDim2.new(percent, -thumb.Size.X.Offset/2, 0, -5)
		onChange(newVal)
	end

	-- 滑块拖动逻辑
	local dragging = false
	thumb.MouseButton1Down:Connect(function()
		dragging = true
	end)
	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = false
		end
	end)
	track.MouseMoved:Connect(function(input)
		if dragging then
			local mousePos = UserInputService:GetMouseLocation()
			local absPos = track.AbsolutePosition
			local absSize = track.AbsoluteSize
			local relativeX = math.clamp(mousePos.X - absPos.X, 0, absSize.X)
			local percent = relativeX / absSize.X
			local newVal = min + percent * (max - min)
			updateValue(newVal)
		end
	end)

	-- 输入框手动输入
	valueBox.FocusLost:Connect(function()
		local val = tonumber(valueBox.Text)
		if val then
			updateValue(val)
		else
			valueBox.Text = tostring(currentValue)
		end
	end)

	yOffset = yOffset + 30
	return valueBox
end

